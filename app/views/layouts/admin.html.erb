<!DOCTYPE html>
<html lang="ru">
  <head>
    <title>Айаши — Админ панель</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Raleway:wght@600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-60 bg-slate-900 fixed inset-y-0 left-0 flex flex-col z-20">
        <div class="p-6 border-b border-slate-700">
          <a href="<%= admin_root_path %>" class="flex items-center gap-2">
            <div class="w-8 h-8 bg-primary-500 rounded-lg flex items-center justify-center">
              <span class="text-white font-bold text-sm font-display">А</span>
            </div>
            <span class="text-white font-display font-semibold text-lg">Айаши</span>
          </a>
          <p class="text-slate-400 text-xs mt-1">Панель управления</p>
        </div>

        <nav class="flex-1 p-4 space-y-1">
          <%= link_to admin_inquiries_path,
                class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-300 hover:bg-slate-800 hover:text-white transition-colors group #{request.path.start_with?('/admin/inquiries') ? 'bg-slate-800 text-white' : ''}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            <span class="font-medium">Заявки</span>
            <% new_count = Inquiry.new_inquiry.count %>
            <% if new_count > 0 %>
              <span class="ml-auto bg-primary-500 text-white text-xs font-bold px-2 py-0.5 rounded-full"><%= new_count %></span>
            <% end %>
          <% end %>

          <%= link_to admin_services_path,
                class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-300 hover:bg-slate-800 hover:text-white transition-colors #{request.path.start_with?('/admin/services') ? 'bg-slate-800 text-white' : ''}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
            <span class="font-medium">Услуги</span>
          <% end %>

          <div class="border-t border-slate-700 my-3"></div>

          <%= link_to root_path, target: "_blank",
                class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400 hover:bg-slate-800 hover:text-white transition-colors text-sm" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Открыть сайт
          <% end %>
        </nav>

        <div class="p-4 border-t border-slate-700">
          <p class="text-slate-400 text-xs mb-2 truncate"><%= current_admin.email %></p>
          <%= button_to destroy_admin_session_path, method: :delete,
                class: "w-full text-left text-slate-400 hover:text-red-400 text-sm transition-colors flex items-center gap-2" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            Выйти
          <% end %>
        </div>
      </aside>

      <!-- Main content -->
      <div class="ml-60 flex-1 flex flex-col">
        <header class="bg-white border-b border-gray-200 px-8 py-4 sticky top-0 z-10">
          <div class="flex items-center justify-between">
            <h1 class="text-xl font-display font-semibold text-ink"><%= content_for?(:page_title) ? yield(:page_title) : "Панель управления" %></h1>
            <% if content_for?(:header_actions) %>
              <%= yield(:header_actions) %>
            <% end %>
          </div>
        </header>

        <main class="flex-1 p-8">
          <%= render "shared/flash" %>
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
