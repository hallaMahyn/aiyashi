<!DOCTYPE html>
<html lang="ru">
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} — Айаши" : "Айаши — Медицинский туризм в Китай" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for?(:description) ? yield(:description) : "Айаши — медицинский туризм из России в Китай. Лечение зубов, офтальмология, ортопедия и другие услуги по доступным ценам в лучших клиниках Китая." %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Raleway:wght@600;700;800&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white text-ink antialiased">
    <%= render "shared/navbar" %>

    <%= render "shared/flash" %>

    <main>
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
