<% content_for :page_title, "Услуги" %>
<% content_for :header_actions do %>
  <%= link_to new_admin_service_path, class: "btn-primary text-sm py-2" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    Добавить услугу
  <% end %>
<% end %>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <% if @services.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
            <th class="px-4 py-3 text-left w-8"></th>
            <th class="px-4 py-3 text-left">Услуга</th>
            <th class="px-4 py-3 text-left">Категория</th>
            <th class="px-4 py-3 text-left">Цена</th>
            <th class="px-4 py-3 text-center">Статус</th>
            <th class="px-4 py-3 text-right">Действия</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @services.each do |service| %>
            <tr class="hover:bg-gray-50 transition-colors" id="service-<%= service.id %>">
              <td class="px-4 py-3">
                <span class="text-gray-300 cursor-grab">⠿</span>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <% if service.image.attached? %>
                    <div class="w-10 h-10 flex-shrink-0 rounded-lg overflow-hidden">
                      <%= image_tag service.image, class: "w-full h-full object-cover", alt: service.name %>
                    </div>
                  <% else %>
                    <div class="w-10 h-10 flex-shrink-0 bg-primary-50 rounded-lg flex items-center justify-center">
                      <svg class="w-5 h-5 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                    </div>
                  <% end %>
                  <div>
                    <p class="font-medium text-ink"><%= service.name %></p>
                    <% if service.description.present? %>
                      <p class="text-gray-400 text-xs line-clamp-1 max-w-xs"><%= service.description %></p>
                    <% end %>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3">
                <span class="badge bg-primary-50 text-primary-700"><%= service.category_label %></span>
              </td>
              <td class="px-4 py-3 font-medium text-ink"><%= service.price_display %></td>
              <td class="px-4 py-3 text-center">
                <%= button_to toggle_active_admin_service_path(service), method: :patch,
                      class: "inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full font-medium transition-colors #{service.active? ? 'bg-green-100 text-green-700 hover:bg-green-200' : 'bg-gray-100 text-gray-500 hover:bg-gray-200'}" do %>
                  <%= service.active? ? "Активна" : "Скрыта" %>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <%= link_to edit_admin_service_path(service), class: "text-gray-400 hover:text-primary-600 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                  <% end %>
                  <%= button_to admin_service_path(service), method: :delete,
                        class: "text-gray-400 hover:text-red-500 transition-colors",
                        form: { data: { turbo_confirm: "Удалить услугу «#{service.name}»?" } } do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-16">
      <svg class="w-12 h-12 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
      </svg>
      <p class="text-gray-400 mb-4">Услуги ещё не добавлены</p>
      <%= link_to new_admin_service_path, class: "btn-primary text-sm" do %>
        Добавить первую услугу
      <% end %>
    </div>
  <% end %>
</div>
