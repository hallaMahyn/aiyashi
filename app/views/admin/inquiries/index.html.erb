<% content_for :page_title, "Заявки" %>

<!-- Stats -->
<div class="grid grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
    <p class="text-sm text-gray-500 mb-1">Всего</p>
    <p class="text-2xl font-display font-bold text-ink"><%= @stats[:total] %></p>
  </div>
  <div class="bg-blue-50 rounded-xl p-4 border border-blue-100">
    <p class="text-sm text-blue-600 mb-1">Новые</p>
    <p class="text-2xl font-display font-bold text-blue-700"><%= @stats[:new_inquiry] %></p>
  </div>
  <div class="bg-yellow-50 rounded-xl p-4 border border-yellow-100">
    <p class="text-sm text-yellow-600 mb-1">В работе</p>
    <p class="text-2xl font-display font-bold text-yellow-700"><%= @stats[:in_progress] %></p>
  </div>
  <div class="bg-green-50 rounded-xl p-4 border border-green-100">
    <p class="text-sm text-green-600 mb-1">Завершены</p>
    <p class="text-2xl font-display font-bold text-green-700"><%= @stats[:completed] %></p>
  </div>
</div>

<!-- Filter tabs -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-6">
  <div class="flex border-b border-gray-100 overflow-x-auto">
    <% [
      [nil, "Все", @stats[:total]],
      ["new_inquiry", "Новые", @stats[:new_inquiry]],
      ["in_progress", "В работе", @stats[:in_progress]],
      ["completed", "Завершены", @stats[:completed]],
      ["cancelled", "Отменены", nil]
    ].each do |status, label, count| %>
      <%= link_to admin_inquiries_path(status: status),
            class: "flex items-center gap-2 px-4 py-3 text-sm font-medium border-b-2 transition-colors whitespace-nowrap #{params[:status].to_s == status.to_s ? 'border-primary-500 text-primary-600' : 'border-transparent text-gray-500 hover:text-gray-700'}" do %>
        <%= label %>
        <% if count && count > 0 %>
          <span class="bg-gray-100 text-gray-600 text-xs px-1.5 py-0.5 rounded-full"><%= count %></span>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <!-- Table -->
  <% if @inquiries.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
            <th class="px-4 py-3 text-left">Дата</th>
            <th class="px-4 py-3 text-left">Имя</th>
            <th class="px-4 py-3 text-left">Телефон</th>
            <th class="px-4 py-3 text-left">Услуга</th>
            <th class="px-4 py-3 text-left">Статус</th>
            <th class="px-4 py-3 text-right">Действия</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @inquiries.each do |inquiry| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3 text-gray-500 whitespace-nowrap">
                <%= inquiry.created_at.strftime("%d.%m.%Y %H:%M") %>
              </td>
              <td class="px-4 py-3 font-medium text-ink"><%= inquiry.name %></td>
              <td class="px-4 py-3 text-gray-600">
                <a href="tel:<%= inquiry.phone %>" class="hover:text-primary-600 transition-colors"><%= inquiry.phone %></a>
              </td>
              <td class="px-4 py-3 text-gray-500"><%= inquiry.service&.name || "—" %></td>
              <td class="px-4 py-3">
                <span class="badge <%= inquiry.status_label[:css] %>"><%= inquiry.status_label[:text] %></span>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <%= link_to admin_inquiry_path(inquiry), class: "text-gray-400 hover:text-primary-600 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                  <% end %>
                  <%= button_to admin_inquiry_path(inquiry), method: :delete,
                        class: "text-gray-400 hover:text-red-500 transition-colors",
                        form: { data: { turbo_confirm: "Удалить заявку от #{inquiry.name}?" } } do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="px-4 py-3 border-t border-gray-100 flex items-center justify-between text-sm">
      <p class="text-gray-500">
        Показано <%= @pagy.from %>–<%= @pagy.to %> из <%= @pagy.count %>
      </p>
      <div class="flex gap-1">
        <% if @pagy.prev %>
          <%= link_to admin_inquiries_path(page: @pagy.prev, status: params[:status]), class: "px-3 py-1.5 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors" do %>
            ← Назад
          <% end %>
        <% end %>
        <% if @pagy.next %>
          <%= link_to admin_inquiries_path(page: @pagy.next, status: params[:status]), class: "px-3 py-1.5 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors" do %>
            Далее →
          <% end %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="text-center py-12">
      <svg class="w-12 h-12 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      <p class="text-gray-400">Заявок нет</p>
    </div>
  <% end %>
</div>
