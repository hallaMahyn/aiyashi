<% content_for :page_title, "Заявка ##{@inquiry.id}" %>
<% content_for :header_actions do %>
  <%= link_to admin_inquiries_path, class: "text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Все заявки
  <% end %>
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Inquiry details -->
  <div class="lg:col-span-2 space-y-4">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h2 class="font-display font-semibold text-ink mb-4">Данные заявки</h2>
      <dl class="space-y-3">
        <div class="flex gap-4">
          <dt class="text-gray-500 text-sm w-28 flex-shrink-0">Дата</dt>
          <dd class="text-ink text-sm font-medium"><%= @inquiry.created_at.strftime("%d.%m.%Y в %H:%M") %></dd>
        </div>
        <div class="flex gap-4">
          <dt class="text-gray-500 text-sm w-28 flex-shrink-0">Имя</dt>
          <dd class="text-ink text-sm font-medium"><%= @inquiry.name %></dd>
        </div>
        <div class="flex gap-4">
          <dt class="text-gray-500 text-sm w-28 flex-shrink-0">Телефон</dt>
          <dd class="text-ink text-sm font-medium">
            <a href="tel:<%= @inquiry.phone %>" class="text-primary-600 hover:underline"><%= @inquiry.phone %></a>
          </dd>
        </div>
        <% if @inquiry.email.present? %>
          <div class="flex gap-4">
            <dt class="text-gray-500 text-sm w-28 flex-shrink-0">Email</dt>
            <dd class="text-ink text-sm font-medium">
              <a href="mailto:<%= @inquiry.email %>" class="text-primary-600 hover:underline"><%= @inquiry.email %></a>
            </dd>
          </div>
        <% end %>
        <% if @inquiry.service.present? %>
          <div class="flex gap-4">
            <dt class="text-gray-500 text-sm w-28 flex-shrink-0">Услуга</dt>
            <dd class="text-ink text-sm font-medium"><%= @inquiry.service.name %></dd>
          </div>
        <% end %>
        <% if @inquiry.message.present? %>
          <div class="flex gap-4">
            <dt class="text-gray-500 text-sm w-28 flex-shrink-0">Сообщение</dt>
            <dd class="text-ink text-sm leading-relaxed"><%= @inquiry.message %></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <!-- Quick actions -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h2 class="font-display font-semibold text-ink mb-4">Быстрые действия</h2>
      <div class="flex flex-wrap gap-3">
        <a href="tel:<%= @inquiry.phone %>" class="flex items-center gap-2 px-4 py-2 bg-primary-50 text-primary-700 rounded-lg text-sm font-medium hover:bg-primary-100 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Позвонить
        </a>
        <a href="https://wa.me/<%= @inquiry.phone.gsub(/[^0-9]/, '') %>" target="_blank"
           class="flex items-center gap-2 px-4 py-2 bg-green-50 text-green-700 rounded-lg text-sm font-medium hover:bg-green-100 transition-colors">
          WhatsApp
        </a>
        <% if @inquiry.email.present? %>
          <a href="mailto:<%= @inquiry.email %>" class="flex items-center gap-2 px-4 py-2 bg-blue-50 text-blue-700 rounded-lg text-sm font-medium hover:bg-blue-100 transition-colors">
            Email
          </a>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Status panel -->
  <div class="lg:col-span-1">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h2 class="font-display font-semibold text-ink mb-4">Управление статусом</h2>

      <div class="mb-4">
        <p class="text-gray-500 text-sm mb-2">Текущий статус</p>
        <span class="badge <%= @inquiry.status_label[:css] %> text-sm px-3 py-1">
          <%= @inquiry.status_label[:text] %>
        </span>
      </div>

      <%= form_with url: update_status_admin_inquiry_path(@inquiry), method: :patch, class: "space-y-3" do |f| %>
        <div>
          <%= label_tag :status, "Изменить статус", class: "form-label" %>
          <%= select_tag :status,
                options_for_select(
                  Inquiry::STATUS_LABELS.map { |k, v| [v[:text], k] },
                  @inquiry.status
                ),
                class: "form-input" %>
        </div>
        <%= f.submit "Обновить статус", class: "w-full btn-primary text-sm py-2.5 cursor-pointer" %>
      <% end %>

      <!-- Note -->
      <div class="border-t border-gray-100 mt-4 pt-4">
        <p class="font-display font-semibold text-ink mb-3">Заметка</p>
        <%= form_with url: admin_inquiry_path(@inquiry), method: :patch, class: "space-y-2" do |f| %>
          <%= text_area_tag :inquiry_note, @inquiry.note, rows: 4,
                class: "form-input resize-none text-sm",
                placeholder: "Внутренние пометки...",
                name: "inquiry[note]" %>
          <%= f.submit "Сохранить заметку", class: "w-full btn-secondary border border-gray-200 text-sm py-2 cursor-pointer" %>
        <% end %>
      </div>

      <div class="border-t border-gray-100 mt-4 pt-4">
        <%= button_to admin_inquiry_path(@inquiry), method: :delete,
              class: "w-full py-2 text-red-500 text-sm hover:bg-red-50 rounded-lg transition-colors font-medium",
              form: { data: { turbo_confirm: "Удалить эту заявку безвозвратно?" } } do %>
          Удалить заявку
        <% end %>
      </div>
    </div>
  </div>
</div>
