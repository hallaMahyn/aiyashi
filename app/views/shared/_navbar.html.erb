<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm" data-controller="mobile-menu">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <%= link_to root_path, class: "flex items-center gap-2 flex-shrink-0" do %>
        <div class="w-9 h-9 bg-primary-500 rounded-xl flex items-center justify-center shadow-sm">
          <span class="text-white font-display font-bold text-base">А</span>
        </div>
        <span class="font-display font-bold text-xl text-ink">Айаши</span>
      <% end %>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-8">
        <%= link_to "Главная", root_path, class: "nav-link #{current_page?(root_path) ? 'nav-link-active' : ''}" %>
        <%= link_to "Услуги", current_page?(root_path) ? "#services" : services_page_path, class: "nav-link #{current_page?(services_page_path) ? 'nav-link-active' : ''}" %>
        <%= link_to "О нас", about_path, class: "nav-link #{current_page?(about_path) ? 'nav-link-active' : ''}" %>
        <%= link_to "Контакты", contacts_path, class: "nav-link #{current_page?(contacts_path) ? 'nav-link-active' : ''}" %>
      </div>

      <!-- CTA + mobile toggle -->
      <div class="flex items-center gap-3">
        <%= link_to "Оставить заявку", contacts_path, class: "hidden sm:inline-flex btn-primary text-sm py-2" %>

        <!-- Mobile hamburger -->
        <button data-action="click->mobile-menu#toggle"
                class="md:hidden p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-colors"
                aria-label="Меню">
          <svg data-mobile-menu-target="openIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg data-mobile-menu-target="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div data-mobile-menu-target="menu" class="hidden md:hidden border-t border-gray-100 py-4 space-y-2">
      <%= link_to "Главная", root_path, class: "block px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-primary-600 font-medium transition-colors" %>
      <%= link_to "Услуги", current_page?(root_path) ? "#services" : services_page_path, class: "block px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-primary-600 font-medium transition-colors" %>
      <%= link_to "О нас", about_path, class: "block px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-primary-600 font-medium transition-colors" %>
      <%= link_to "Контакты", contacts_path, class: "block px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-primary-600 font-medium transition-colors" %>
      <%= link_to "Оставить заявку", contacts_path, class: "block mt-3 btn-primary text-center text-sm" %>
    </div>
  </div>
</nav>
