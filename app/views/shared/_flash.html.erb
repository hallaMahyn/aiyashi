<% flash.each do |type, message| %>
  <% css = type.to_s == "notice" ? "bg-green-50 border-green-400 text-green-800" : "bg-red-50 border-red-400 text-red-800" %>
  <div class="border-l-4 p-4 <%= css %> mx-4 mt-2 mb-4 rounded-r-lg flex justify-between items-start"
       data-controller="dismiss-flash">
    <p class="text-sm font-medium"><%= message %></p>
    <button data-action="click->dismiss-flash#close" class="ml-4 flex-shrink-0 opacity-60 hover:opacity-100 transition-opacity">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
<% end %>
