<% content_for :title, "Контакты и заявка" %>

<!-- Hero -->
<section class="bg-primary-50 py-14">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="section-title mb-3">Связаться с нами</h1>
    <p class="section-subtitle">Оставьте заявку или задайте вопрос — мы ответим в течение 2 часов</p>
  </div>
</section>

<section class="py-14 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Contact info -->
      <div>
        <h2 class="text-xl font-display font-semibold text-ink mb-6">Наши контакты</h2>

        <div class="space-y-4 mb-8">
          <a href="tel:+78005553535" class="flex items-center gap-4 p-4 bg-primary-50 rounded-xl hover:bg-primary-100 transition-colors group">
            <div class="w-10 h-10 bg-primary-500 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-primary-600 transition-colors">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-ink">+7 (800) 555-35-35</p>
              <p class="text-gray-500 text-sm">Звонок бесплатный</p>
            </div>
          </a>

          <a href="mailto:info@aiyashi.ru" class="flex items-center gap-4 p-4 bg-primary-50 rounded-xl hover:bg-primary-100 transition-colors group">
            <div class="w-10 h-10 bg-primary-500 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-ink">info@aiyashi.ru</p>
              <p class="text-gray-500 text-sm">Ответим в течение часа</p>
            </div>
          </a>

          <a href="https://wa.me/78005553535" class="flex items-center gap-4 p-4 bg-green-50 rounded-xl hover:bg-green-100 transition-colors group">
            <div class="w-10 h-10 bg-green-500 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-ink">WhatsApp</p>
              <p class="text-gray-500 text-sm">Написать в WhatsApp</p>
            </div>
          </a>

          <div class="flex items-center gap-4 p-4 bg-slate-50 rounded-xl">
            <div class="w-10 h-10 bg-slate-500 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-ink">Пн–Вс, 09:00–21:00</p>
              <p class="text-gray-500 text-sm">Московское время</p>
            </div>
          </div>
        </div>

        <!-- Yandex Maps placeholder -->
        <div class="bg-slate-100 rounded-2xl h-56 flex items-center justify-center">
          <div class="text-center text-gray-400">
            <svg class="w-12 h-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-sm">Карта расположения офиса</p>
          </div>
        </div>
      </div>

      <!-- Inquiry form -->
      <div>
        <h2 class="text-xl font-display font-semibold text-ink mb-6">Оставить заявку</h2>

        <%= form_with model: @inquiry, url: inquiries_path, class: "space-y-4" do |f| %>
          <% if @inquiry.errors.any? %>
            <div class="bg-red-50 border border-red-200 rounded-xl p-4">
              <p class="font-medium text-red-800 text-sm mb-2">Пожалуйста, исправьте ошибки:</p>
              <ul class="list-disc list-inside space-y-1">
                <% @inquiry.errors.full_messages.each do |msg| %>
                  <li class="text-red-700 text-sm"><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :name, "Ваше имя *", class: "form-label" %>
              <%= f.text_field :name, class: "form-input", placeholder: "Иван Иванов", required: true %>
            </div>
            <div>
              <%= f.label :phone, "Телефон *", class: "form-label" %>
              <%= f.telephone_field :phone, class: "form-input", placeholder: "+7 (999) 123-45-67", required: true %>
            </div>
          </div>

          <div>
            <%= f.label :email, "Email", class: "form-label" %>
            <%= f.email_field :email, class: "form-input", placeholder: "ivan@example.com" %>
          </div>

          <div>
            <%= f.label :service_id, "Интересующая услуга", class: "form-label" %>
            <%= f.select :service_id,
                  options_from_collection_for_select(@services, :id, :name, params[:service_id]),
                  { include_blank: "Выберите услугу (необязательно)" },
                  class: "form-input" %>
          </div>

          <div>
            <%= f.label :message, "Ваш вопрос или пожелания", class: "form-label" %>
            <%= f.text_area :message, rows: 4, class: "form-input resize-none", placeholder: "Расскажите о вашем запросе..." %>
          </div>

          <div>
            <%= f.submit "Отправить заявку", class: "w-full btn-primary py-4 text-base cursor-pointer" %>
          </div>

          <p class="text-gray-400 text-xs text-center">
            Нажимая кнопку, вы соглашаетесь с обработкой персональных данных в соответствии с ФЗ № 152
          </p>
        <% end %>
      </div>
    </div>
  </div>
</section>
