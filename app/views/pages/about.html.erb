<% content_for :title, "О нас" %>

<!-- Hero -->
<section class="bg-primary-50 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="text-sm text-gray-400 mb-4">
      <%= link_to "Главная", root_path, class: "hover:text-primary-600 transition-colors" %>
      <span class="mx-2">›</span>
      <span class="text-gray-600">О нас</span>
    </nav>
    <div class="max-w-3xl">
      <h1 class="section-title mb-4">О компании Айаши</h1>
      <p class="text-gray-600 text-lg leading-relaxed">
        Мы помогаем россиянам получить доступ к высококачественной и доступной медицинской помощи в Китае — от первой консультации до возвращения домой.
      </p>
    </div>
  </div>
</section>

<!-- Story -->
<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="badge bg-primary-100 text-primary-700 mb-4">Наша история</span>
        <h2 class="text-2xl font-display font-bold text-ink mb-4">Более 10 лет опыта в медицинском туризме</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          Айаши была основана командой врачей и организаторов, которые на себе убедились: качественное лечение в Китае доступно каждому, если рядом есть надёжный проводник.
        </p>
        <p class="text-gray-600 leading-relaxed mb-6">
          За годы работы мы выстроили партнёрские отношения с ведущими клиниками Харбина, Пекина и Шэньяна. Каждый партнёр прошёл строгую проверку по критериям качества, оснащённости и репутации.
        </p>
        <div class="grid grid-cols-3 gap-4">
          <div class="text-center p-4 bg-primary-50 rounded-xl">
            <div class="text-2xl font-display font-bold text-primary-600">500+</div>
            <div class="text-gray-500 text-xs mt-1">пациентов</div>
          </div>
          <div class="text-center p-4 bg-gold-100 rounded-xl">
            <div class="text-2xl font-display font-bold text-gold-600">15+</div>
            <div class="text-gray-500 text-xs mt-1">клиник</div>
          </div>
          <div class="text-center p-4 bg-primary-50 rounded-xl">
            <div class="text-2xl font-display font-bold text-primary-600">98%</div>
            <div class="text-gray-500 text-xs mt-1">довольных</div>
          </div>
        </div>
      </div>
      <div class="bg-primary-100 rounded-2xl h-80 flex items-center justify-center">
        <svg class="w-24 h-24 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<!-- Why China -->
<section class="py-16 bg-slate-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-display font-bold text-white mb-3">Почему Китай?</h2>
      <p class="text-slate-400 max-w-2xl mx-auto">Китайская медицина сочетает современные технологии с многовековой традицией и конкурентными ценами</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <% [
        { num: "в 2-4 раза", label: "дешевле", desc: "чем аналогичное лечение в России или Европе" },
        { num: "мировой", label: "уровень", desc: "технологий и медицинского оборудования в ведущих клиниках" },
        { num: "быстрые", label: "сроки", desc: "минимальное ожидание, оперативная запись к специалистам" }
      ].each do |stat| %>
        <div class="text-center p-6 bg-slate-800 rounded-2xl">
          <div class="text-4xl font-display font-extrabold text-gold-400 mb-1"><%= stat[:num] %></div>
          <div class="text-white font-semibold text-xl mb-2"><%= stat[:label] %></div>
          <p class="text-slate-400 text-sm"><%= stat[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Partner clinics -->
<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="section-title mb-3">Наши партнёрские клиники</h2>
      <p class="section-subtitle mx-auto text-center">Только проверенные учреждения с международной аккредитацией</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% [
        { city: "Харбин", name: "Первая Провинциальная Больница Хэйлунцзяна", spec: "Стоматология, ортопедия, онкология", badge: "JCI" },
        { city: "Пекин", name: "Международный Медицинский Центр Пекина", spec: "Офтальмология, кардиология, чекап", badge: "ISO 9001" },
        { city: "Шэньян", name: "Клиника Красоты и Здоровья Шэньян", spec: "Косметология, пластическая хирургия", badge: "AAA" }
      ].each do |clinic| %>
        <div class="border border-gray-100 rounded-2xl p-6 hover:border-primary-200 hover:shadow-md transition-all">
          <div class="flex items-start justify-between mb-4">
            <div>
              <span class="text-primary-600 text-sm font-medium"><%= clinic[:city] %></span>
              <h3 class="font-display font-semibold text-ink mt-1"><%= clinic[:name] %></h3>
            </div>
            <span class="badge bg-gold-100 text-gold-700 flex-shrink-0 ml-2"><%= clinic[:badge] %></span>
          </div>
          <p class="text-gray-500 text-sm"><%= clinic[:spec] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Team -->
<section class="py-16 bg-primary-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="section-title mb-3">Наша команда</h2>
      <p class="section-subtitle mx-auto text-center">Профессионалы, которые будут рядом на каждом этапе</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <% [
        { name: "Ольга Семёнова", title: "Руководитель", desc: "10 лет в медицинском туризме, специалист по Китаю" },
        { name: "Игорь Чан", title: "Переводчик-куратор", desc: "Русско-китайский медицинский переводчик, Харбин" },
        { name: "Наталья Крылова", title: "Менеджер по визам", desc: "Помогает с оформлением медицинских виз и документов" },
        { name: "Алина Петрова", title: "Координатор", desc: "Организация трансфера, проживания и расписания лечения" }
      ].each do |member| %>
        <div class="bg-white rounded-2xl p-6 text-center shadow-sm">
          <div class="w-20 h-20 mx-auto bg-primary-200 rounded-full flex items-center justify-center mb-4">
            <span class="text-primary-700 font-display font-bold text-2xl"><%= member[:name][0] %></span>
          </div>
          <h3 class="font-display font-semibold text-ink"><%= member[:name] %></h3>
          <p class="text-primary-600 text-sm font-medium mt-1 mb-2"><%= member[:title] %></p>
          <p class="text-gray-500 text-xs leading-relaxed"><%= member[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
