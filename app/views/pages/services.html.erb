<% content_for :title, "Услуги и цены" %>

<!-- Page hero -->
<section class="bg-slate-50 border-b border-gray-200 py-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="text-sm text-gray-400 mb-3">
      <%= link_to "Главная", root_path, class: "hover:text-primary-600 transition-colors" %>
      <span class="mx-2">—</span>
      <span class="text-gray-600">Цены</span>
      <% if @selected_category.present? %>
        <span class="mx-2">—</span>
        <span class="text-gray-800 font-medium"><%= Service::CATEGORY_LABELS[@selected_category] %></span>
      <% end %>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-display font-bold text-ink">
      <%= @selected_category.present? ? Service::CATEGORY_LABELS[@selected_category] : "Услуги и цены" %>
    </h1>
  </div>
</section>

<!-- Two-column layout -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex flex-col md:flex-row gap-8 md:items-start">

    <!-- Sidebar: category navigation -->
    <aside class="hidden md:block w-64 flex-shrink-0">
      <div class="bg-white border border-gray-200 rounded-lg overflow-hidden sticky top-24">
        <% Service::CATEGORIES.each do |cat| %>
          <%= link_to services_page_path(category: cat),
                class: "flex items-center gap-2 px-5 py-3.5 text-sm border-b border-gray-100 last:border-b-0 transition-colors #{@selected_category == cat ? 'bg-primary-50 text-primary-700 font-semibold border-l-4 border-l-primary-500' : 'text-gray-700 hover:bg-gray-50 hover:text-primary-600'}" do %>
            <%= Service::CATEGORY_LABELS[cat] %>
          <% end %>
        <% end %>
        <% if @selected_category.present? %>
          <div class="border-t border-gray-200">
            <%= link_to "Все категории", services_page_path,
                  class: "flex items-center gap-2 px-5 py-3 text-sm text-gray-400 hover:text-primary-600 transition-colors" %>
          </div>
        <% end %>
      </div>
    </aside>

    <!-- Mobile: horizontal category tabs -->
    <div class="md:hidden w-full mb-6 -mt-2">
      <div class="flex flex-wrap gap-2">
        <%= link_to "Все", services_page_path,
              class: "flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium border transition-colors #{@selected_category.blank? ? 'bg-primary-500 text-white border-primary-500' : 'border-gray-300 text-gray-600 hover:border-primary-400 hover:text-primary-600'}" %>
        <% Service::CATEGORIES.each do |cat| %>
          <%= link_to Service::CATEGORY_LABELS[cat], services_page_path(category: cat),
                class: "flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium border transition-colors #{@selected_category == cat ? 'bg-primary-500 text-white border-primary-500' : 'border-gray-300 text-gray-600 hover:border-primary-400 hover:text-primary-600'}" %>
        <% end %>
      </div>
    </div>

    <!-- Main content: service rows grouped by category -->
    <main class="flex-1 min-w-0">
      <% if @services_by_category.any? %>
        <% @services_by_category.each do |category, services| %>
          <div class="mb-10">
            <!-- Category heading (shown when "All" is selected) -->
            <% if @selected_category.blank? %>
              <h2 class="text-xl font-display font-bold text-ink mb-4 pb-3 border-b-2 border-primary-500 inline-block">
                <%= Service::CATEGORY_LABELS[category] %>
              </h2>
            <% end %>

            <!-- Service rows -->
            <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
              <% services.each_with_index do |service, i| %>
                <div class="flex items-center gap-4 px-6 py-4 <%= i < services.size - 1 ? 'border-b border-gray-100' : '' %> hover:bg-gray-50 transition-colors group">
                  <!-- Name + description -->
                  <div class="flex-1 min-w-0">
                    <p class="font-semibold text-ink text-sm sm:text-base leading-snug"><%= service.name %></p>
                    <% if service.description.present? %>
                      <p class="text-gray-400 text-xs mt-0.5 leading-relaxed"><%= service.description %></p>
                    <% end %>
                  </div>
                  <!-- Price -->
                  <div class="flex-shrink-0 text-right w-32 sm:w-40">
                    <span class="text-primary-600 font-bold text-base sm:text-lg whitespace-nowrap"><%= service.price_display %></span>
                  </div>
                  <!-- CTA button -->
                  <div class="flex-shrink-0 hidden sm:block">
                    <%= link_to contacts_path(service_id: service.id),
                          class: "btn-primary text-sm py-2 px-4 whitespace-nowrap" do %>
                      Записаться
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>

            <!-- Mobile: single CTA at bottom of category -->
            <div class="sm:hidden mt-3 text-center">
              <%= link_to "Записаться на приём", contacts_path, class: "btn-primary text-sm px-6 py-2.5" %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-20 bg-white border border-gray-200 rounded-lg">
          <p class="text-gray-400 mb-4">Услуги не найдены</p>
          <%= link_to "Посмотреть все услуги", services_page_path, class: "btn-primary" %>
        </div>
      <% end %>
    </main>

  </div>
</div>
