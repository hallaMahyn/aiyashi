<% content_for :title, "Услуги и цены" %>

<!-- Page hero -->
<section class="bg-primary-50 py-14">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="text-sm text-gray-400 mb-4">
      <%= link_to "Главная", root_path, class: "hover:text-primary-600 transition-colors" %>
      <span class="mx-2">›</span>
      <span class="text-gray-600">Услуги</span>
    </nav>
    <h1 class="section-title mb-3">Услуги и цены</h1>
    <p class="section-subtitle">Лечение в лучших клиниках Китая по фиксированным ценам</p>
  </div>
</section>

<!-- Category filter -->
<section class="bg-white border-b border-gray-100 sticky top-16 z-30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex gap-2 overflow-x-auto py-3 scrollbar-hide">
      <%= link_to "Все", services_page_path,
            class: "flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-colors #{@selected_category.blank? ? 'bg-primary-500 text-white' : 'text-gray-500 hover:text-primary-600 hover:bg-primary-50'}" %>
      <% Service::CATEGORIES.each do |cat| %>
        <%= link_to Service::CATEGORY_LABELS[cat], services_page_path(category: cat),
              class: "flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-colors #{@selected_category == cat ? 'bg-primary-500 text-white' : 'text-gray-500 hover:text-primary-600 hover:bg-primary-50'}" %>
      <% end %>
    </div>
  </div>
</section>

<!-- Services by category -->
<section class="py-12 bg-slate-50 min-h-96">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if @services_by_category.any? %>
      <% @services_by_category.each do |category, services| %>
        <div class="mb-12">
          <h2 class="text-2xl font-display font-bold text-ink mb-6 flex items-center gap-3">
            <span class="w-1 h-7 bg-primary-500 rounded-full"></span>
            <%= Service::CATEGORY_LABELS[category] || category %>
          </h2>
          <div class="space-y-4">
            <% services.each do |service| %>
              <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow flex flex-col sm:flex-row gap-6">
                <% if service.image.attached? %>
                  <div class="sm:w-40 sm:h-32 w-full h-44 flex-shrink-0">
                    <%= image_tag service.image, class: "w-full h-full object-cover rounded-xl", alt: service.name %>
                  </div>
                <% else %>
                  <div class="sm:w-40 sm:h-32 w-full h-32 flex-shrink-0 bg-primary-50 rounded-xl flex items-center justify-center">
                    <svg class="w-10 h-10 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                    </svg>
                  </div>
                <% end %>
                <div class="flex-1">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
                    <div>
                      <h3 class="font-display font-semibold text-xl text-ink mb-2"><%= service.name %></h3>
                      <% if service.description.present? %>
                        <p class="text-gray-500 text-sm leading-relaxed"><%= service.description %></p>
                      <% end %>
                    </div>
                    <div class="flex-shrink-0 text-right">
                      <div class="text-2xl font-display font-bold text-primary-600"><%= service.price_display %></div>
                      <%= link_to "Записаться", contacts_path(service_id: service.id), class: "mt-2 inline-block btn-primary text-sm py-2 px-4" %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-20">
        <div class="w-20 h-20 mx-auto bg-gray-100 rounded-full flex items-center justify-center mb-4">
          <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <h3 class="font-display font-semibold text-gray-600 text-xl mb-2">Услуги не найдены</h3>
        <p class="text-gray-400 mb-6">По выбранной категории пока нет услуг</p>
        <%= link_to "Посмотреть все услуги", services_page_path, class: "btn-primary" %>
      </div>
    <% end %>
  </div>
</section>

<!-- Bottom CTA -->
<section class="py-14 bg-white">
  <div class="max-w-3xl mx-auto px-4 text-center">
    <h2 class="section-title mb-4">Не нашли нужную услугу?</h2>
    <p class="text-gray-500 mb-6">Мы работаем с широким спектром медицинских направлений. Напишите нам — мы подберём подходящий вариант.</p>
    <%= link_to contacts_path, class: "btn-primary" do %>
      Задать вопрос
    <% end %>
  </div>
</section>
