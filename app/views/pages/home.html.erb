<% content_for :title, "Медицинский туризм в Китай" %>

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-slate-900">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, #1a9e5c 0%, transparent 50%), radial-gradient(circle at 75% 75%, #e8b84b 0%, transparent 50%);"></div>
  </div>
  <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"></div>

  <!-- Decorative circles -->
  <div class="absolute top-20 right-20 w-64 h-64 bg-primary-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 left-20 w-96 h-96 bg-gold-400/10 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-24">
    <!-- Trust badge -->
    <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 text-white/80 text-sm mb-8">
      <span class="w-2 h-2 bg-primary-400 rounded-full animate-pulse"></span>
      Более 500 пациентов прошли лечение
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-extrabold text-white mb-6 leading-tight">
      Лечение в Китае —<br>
      <span class="text-primary-400">доступно</span>, безопасно,<br>
      эффективно
    </h1>

    <p class="text-lg sm:text-xl text-slate-300 mb-10 max-w-2xl mx-auto leading-relaxed">
      Айаши — ваш личный куратор от заявки до возвращения домой. Лучшие клиники Китая, русскоязычное сопровождение, прозрачные цены.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <%= link_to contacts_path, class: "btn-primary text-base px-8 py-4" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        Оставить заявку
      <% end %>
      <%= link_to services_page_path, class: "btn-outline text-base px-8 py-4" do %>
        Наши услуги
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>

    <!-- Stats -->
    <div class="mt-16 grid grid-cols-3 gap-8 max-w-lg mx-auto">
      <div class="text-center">
        <div class="text-3xl font-display font-bold text-gold-400">10+</div>
        <div class="text-slate-400 text-sm mt-1">лет опыта</div>
      </div>
      <div class="text-center border-x border-white/10">
        <div class="text-3xl font-display font-bold text-gold-400">500+</div>
        <div class="text-slate-400 text-sm mt-1">пациентов</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-display font-bold text-gold-400">15+</div>
        <div class="text-slate-400 text-sm mt-1">клиник-партнёров</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 text-white/40 animate-bounce">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<!-- Services Preview -->
<% if @featured_services.any? %>
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="section-title">Наши услуги</h2>
      <p class="section-subtitle mx-auto text-center">Высококачественное медицинское обслуживание в ведущих клиниках Китая</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @featured_services.each do |service| %>
        <div class="card overflow-hidden group">
          <!-- Service image / placeholder -->
          <div class="h-44 bg-gradient-to-br from-primary-50 to-primary-100 flex items-center justify-center overflow-hidden">
            <% if service.image.attached? %>
              <%= image_tag service.image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", alt: service.name %>
            <% else %>
              <div class="text-center">
                <div class="w-16 h-16 mx-auto bg-primary-200 rounded-2xl flex items-center justify-center mb-2">
                  <svg class="w-8 h-8 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                  </svg>
                </div>
              </div>
            <% end %>
          </div>

          <div class="p-5">
            <span class="badge bg-primary-100 text-primary-700 mb-3"><%= service.category_label %></span>
            <h3 class="font-display font-semibold text-lg text-ink mb-2"><%= service.name %></h3>
            <% if service.description.present? %>
              <p class="text-gray-500 text-sm leading-relaxed line-clamp-2 mb-4"><%= service.description %></p>
            <% end %>
            <div class="flex items-center justify-between">
              <span class="text-primary-600 font-semibold text-base"><%= service.price_display %></span>
              <%= link_to "Узнать стоимость →", contacts_path, class: "text-sm text-gray-400 hover:text-primary-600 transition-colors" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="text-center mt-10">
      <%= link_to services_page_path, class: "btn-secondary border border-primary-200 px-8 py-3" do %>
        Все услуги и цены
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- Why Us -->
<section class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="section-title">Почему выбирают нас</h2>
      <p class="section-subtitle mx-auto text-center">Мы берём на себя все организационные вопросы — вы сосредоточены на лечении</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% [
        { icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", title: "Сертифицированные клиники", desc: "Работаем только с аккредитованными медицинскими учреждениями Китая с международными стандартами качества" },
        { icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z", title: "Персональный куратор", desc: "Ваш русскоязычный куратор сопровождает вас на каждом этапе — от выбора клиники до возвращения домой" },
        { icon: "M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z", title: "Трансфер и виза", desc: "Помогаем с оформлением медицинской визы, организуем трансфер и размещение рядом с клиникой" },
        { icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z", title: "Прозрачные цены", desc: "Полная стоимость лечения обсуждается до поездки. Никаких скрытых платежей и неожиданных расходов" },
        { icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z", title: "Гарантия качества", desc: "Контролируем весь процесс лечения и гарантируем соответствие заявленным стандартам медицинской помощи" },
        { icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z", title: "Поддержка 24/7", desc: "Наши специалисты на связи круглосуточно во время вашего пребывания в Китае" }
      ].each do |item| %>
        <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item[:icon] %>"/>
            </svg>
          </div>
          <h3 class="font-display font-semibold text-ink mb-2"><%= item[:title] %></h3>
          <p class="text-gray-500 text-sm leading-relaxed"><%= item[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- How it works -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="section-title">Как это работает</h2>
      <p class="section-subtitle mx-auto text-center">Простой путь от заявки до успешного лечения</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-5 gap-6">
      <% [
        { num: "1", title: "Заявка", desc: "Оставьте заявку на сайте или позвоните нам" },
        { num: "2", title: "Консультация", desc: "Бесплатная консультация и подбор оптимальной клиники" },
        { num: "3", title: "Планирование", desc: "Оформление визы, бронирование перелёта и жилья" },
        { num: "4", title: "Лечение", desc: "Лечение в Китае с куратором-сопровождающим" },
        { num: "5", title: "Возвращение", desc: "Возвращение домой с результатами и поддержкой" }
      ].each_with_index do |step, idx| %>
        <div class="text-center relative">
          <div class="w-14 h-14 mx-auto bg-gold-400 rounded-full flex items-center justify-center mb-4 shadow-md">
            <span class="text-white font-display font-bold text-xl"><%= step[:num] %></span>
          </div>
          <h3 class="font-display font-semibold text-ink mb-2"><%= step[:title] %></h3>
          <p class="text-gray-500 text-sm leading-relaxed"><%= step[:desc] %></p>
          <% if idx < 4 %>
            <div class="hidden sm:block absolute top-7 left-full w-full h-0.5 bg-gold-200 -translate-x-1/2 z-0"></div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="py-20 bg-primary-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="section-title">Отзывы пациентов</h2>
      <p class="section-subtitle mx-auto text-center">Что говорят те, кто уже прошёл лечение с нами</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% [
        { name: "Марина К.", city: "Москва", service: "Имплантация зубов", text: "Айаши организовали всё идеально — виза, перелёт, размещение. Куратор была рядом на каждом шагу. Качество лечения превзошло все ожидания, а цена оказалась в 3 раза ниже московской!", rating: 5 },
        { name: "Алексей П.", city: "Санкт-Петербург", service: "Лазерная коррекция зрения", text: "Сомневался долго, но ни капли не пожалел. Операция прошла быстро, клиника на высшем уровне. Теперь вижу без очков впервые за 15 лет. Спасибо команде Айаши!", rating: 5 },
        { name: "Светлана В.", city: "Екатеринбург", service: "Эндопротезирование", text: "После эндопротезирования тазобедренного сустава в Харбине я снова хожу без боли. Полное сопровождение, русскоязычный переводчик, комфортная реабилитация — всё на отлично.", rating: 5 }
      ].each do |review| %>
        <div class="card bg-white p-6">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            <% review[:rating].times do %>
              <svg class="w-4 h-4 text-gold-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            <% end %>
          </div>
          <blockquote class="text-gray-600 text-sm leading-relaxed mb-4 italic">"<%= review[:text] %>"</blockquote>
          <div class="border-t border-gray-100 pt-4">
            <p class="font-semibold text-ink text-sm"><%= review[:name] %></p>
            <p class="text-gray-400 text-xs"><%= review[:city] %> · <%= review[:service] %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- CTA Section with inline form -->
<section class="py-20 bg-primary-500">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="text-white">
        <h2 class="text-3xl font-display font-bold mb-4">Готовы начать путь к здоровью?</h2>
        <p class="text-primary-100 text-lg leading-relaxed mb-6">
          Оставьте заявку прямо сейчас — наш специалист свяжется с вами в течение 2 часов и ответит на все вопросы бесплатно.
        </p>
        <ul class="space-y-3 text-primary-100">
          <% ["Бесплатная консультация", "Подбор клиники и врача", "Расчёт стоимости лечения"].each do |item| %>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gold-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <%= item %>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="bg-white rounded-2xl p-6 shadow-xl">
        <%= form_with model: @inquiry, url: inquiries_path, class: "space-y-4" do |f| %>
          <div>
            <%= f.label :name, "Ваше имя *", class: "form-label" %>
            <%= f.text_field :name, class: "form-input", placeholder: "Иван Иванов", required: true %>
          </div>
          <div>
            <%= f.label :phone, "Телефон *", class: "form-label" %>
            <%= f.telephone_field :phone, class: "form-input", placeholder: "+7 (999) 123-45-67", required: true %>
          </div>
          <div>
            <%= f.label :service_id, "Интересующая услуга", class: "form-label" %>
            <%= f.select :service_id,
                  options_from_collection_for_select(@services, :id, :name),
                  { include_blank: "Выберите услугу" },
                  class: "form-input" %>
          </div>
          <div>
            <%= f.submit "Отправить заявку", class: "w-full btn-primary py-3.5 cursor-pointer" %>
          </div>
          <p class="text-gray-400 text-xs text-center">
            Нажимая кнопку, вы соглашаетесь с обработкой персональных данных
          </p>
        <% end %>
      </div>
    </div>
  </div>
</section>
