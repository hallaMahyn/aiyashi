<% content_for :title, "Медицинский туризм в Китай" %>

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden" style="background:#0a0d18">

  <!-- Deep gradient base — dark navy with crimson/gold corners -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 70% 80% at 90% 10%, rgba(160,20,20,0.35) 0%, transparent 55%), radial-gradient(ellipse 60% 70% at 10% 90%, rgba(155,105,10,0.28) 0%, transparent 55%), radial-gradient(ellipse 80% 80% at 50% 50%, rgba(10,15,30,0.9) 30%, transparent 100%)"></div>

  <!-- Chinese decorative top & bottom border lines -->
