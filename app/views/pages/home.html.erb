<!-- How it works -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="section-title">Как это работает</h2>
      <p class="section-subtitle mx-auto text-center">Простой путь от заявки до успешного лечения</p>
    </div>

    <!-- Сквозная линия за кружками -->
    <div class="relative">
      <div class="hidden sm:block absolute top-7 left-[10%] right-[10%] h-0.5 bg-gold-200 z-0"></div>
      <div class="grid grid-cols-1 sm:grid-cols-5 gap-6">
        <% [
          { num: "1", title: "Заявка", desc: "Оставьте заявку на сайте или позвоните нам" },
          { num: "2", title: "Консультация", desc: "Бесплатная консультация и подбор оптимальной клиники" },
          { num: "3", title: "Планирование", desc: "Оформление визы, бронирование перелёта и жилья" },
          { num: "4", title: "Лечение", desc: "Лечение в Китае с куратором-сопровождающим" },
          { num: "5", title: "Возвращение", desc: "Возвращение домой с результатами и поддержкой" }
        ].each do |step| %>
          <div class="text-center relative z-10">
            <div class="w-14 h-14 mx-auto bg-gold-400 rounded-full flex items-center justify-center mb-4 shadow-md">
              <span class="text-white font-display font-bold text-xl"><%= step[:num] %></span>
            </div>
            <h3 class="font-display font-semibold text-ink mb-2"><%= step[:title] %></h3>
            <p class="text-gray-500 text-sm leading-relaxed"><%= step[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="py-20 bg-primary-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="section-title">Отзывы пациентов</h2>
      <p class="section-subtitle mx-auto text-center">Что говорят те, кто уже прошёл лечение с нами</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% [
        { name: "Марина К.", city: "Москва", service: "Имплантация зубов", text: "Айаши организовали всё идеально — виза, перелёт, размещение. Куратор была рядом на каждом шагу. Качество лечения превзошло все ожидания, а цена оказалась в 3 раза ниже московской!", rating: 5 },
        { name: "Алексей П.", city: "Санкт-Петербург", service: "Лазерная коррекция зрения", text: "Сомневался долго, но ни капли не пожалел. Операция прошла быстро, клиника на высшем уровне. Теперь вижу без очков впервые за 15 лет. Спасибо команде Айаши!", rating: 5 },
        { name: "Светлана В.", city: "Екатеринбург", service: "Эндопротезирование", text: "После эндопротезирования тазобедренного сустава в Харбине я снова хожу без боли. Полное сопровождение, русскоязычный переводчик, комфортная реабилитация — всё на отлично.", rating: 5 }
      ].each do |review| %>
        <div class="card bg-white p-6">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            <% review[:rating].times do %>
              <svg class="w-4 h-4 text-gold-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            <% end %>
          </div>
          <blockquote class="text-gray-600 text-sm leading-relaxed mb-4 italic">"<%= review[:text] %>"</blockquote>
          <div class="border-t border-gray-100 pt-4">
            <p class="font-semibold text-ink text-sm"><%= review[:name] %></p>
            <p class="text-gray-400 text-xs"><%= review[:city] %> · <%= review[:service] %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- CTA Section with inline form -->
<section class="py-20 bg-primary-500">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="text-white">
        <h2 class="text-3xl font-display font-bold mb-4">Готовы начать путь к здоровью?</h2>
        <p class="text-primary-100 text-lg leading-relaxed mb-6">
          Оставьте заявку прямо сейчас — наш специалист свяжется с вами в течение 2 часов и ответит на все вопросы бесплатно.
        </p>
        <ul class="space-y-3 text-primary-100">
          <% ["Бесплатная консультация", "Подбор клиники и врача", "Расчёт стоимости лечения"].each do |item| %>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gold-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <%= item %>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="bg-white rounded-2xl p-6 shadow-xl">
        <%= form_with model: @inquiry, url: inquiries_path, class: "space-y-4" do |f| %>
          <div>
            <%= f.label :name, "Ваше имя *", class: "form-label" %>
            <%= f.text_field :name, class: "form-input", placeholder: "Иван Иванов", required: true %>
          </div>
          <div>
            <%= f.label :phone, "Телефон *", class: "form-label" %>
            <%= f.telephone_field :phone, class: "form-input", placeholder: "+7 (999) 123-45-67", required: true %>
          </div>
          <div>
            <%= f.label :service_id, "Интересующая услуга", class: "form-label" %>
            <%= f.select :service_id,
                  options_from_collection_for_select(@services, :id, :name),
                  { include_blank: "Выберите услугу" },
                  class: "form-input" %>
          </div>
          <div>
            <%= f.submit "Отправить заявку", class: "w-full btn-primary py-3.5 cursor-pointer" %>
          </div>
          <p class="text-gray-400 text-xs text-center">
            Нажимая кнопку, вы соглашаетесь с обработкой персональных данных
          </p>
        <% end %>
      </div>
    </div>
  </div>
</section>
