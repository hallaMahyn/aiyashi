      <path d="M440 204 Q461 221 450 236 Q438 224 426 208"/>
    </g>
    <!-- Medium cloud -->
    <g fill="#b01818" stroke="#d03030" stroke-width="1" stroke-linejoin="round">
      <path d="M420 110 Q420 84 444 80 Q447 57 464 54 Q481 51 484 74 Q502 70 505 91 Q508 108 492 114 L436 114 Q420 114 420 110Z"/>
      <path d="M422 112 Q407 124 415 134 Q422 126 430 114"/>
      <path d="M503 112 Q518 124 510 134 Q503 126 495 114"/>
    </g>
    <!-- Small cloud cluster -->
    <g fill="#9a1414" stroke="#c03030" stroke-width="0.8" stroke-linejoin="round" opacity="0.9">
      <path d="M250 290 Q250 268 268 265 Q270 246 283 244 Q296 242 298 260 Q310 257 312 272 Q314 284 303 288 L262 288 Q250 288 250 290Z"/>
      <path d="M252 288 Q241 298 246 307 Q252 300 258 289"/>
      <path d="M310 288 Q321 298 316 307 Q310 300 304 289"/>
    </g>
    <!-- Tiny accent clouds -->
    <g fill="#881010" stroke="#bb2020" stroke-width="0.7" opacity="0.7">
      <path d="M470 220 Q470 207 480 205 Q482 194 489 193 Q496 192 497 202 Q505 200 506 209 Q507 216 501 219 L476 219 Q470 219 470 220Z"/>
    </g>
    <g fill="#881010" stroke="#bb2020" stroke-width="0.7" opacity="0.5">
      <path d="M180 170 Q180 160 188 158 Q189 150 195 149 Q201 148 202 156 Q208 154 209 162 Q210 168 205 170 L186 170 Q180 170 180 170Z"/>
    </g>
  </svg>

  <!-- 祥云 Auspicious clouds — bottom left (gold tones) -->
  <svg class="absolute bottom-0 left-0 opacity-[0.11] pointer-events-none" width="400" height="320" viewBox="0 0 400 320" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g fill="#b07800" stroke="#d09020" stroke-width="1.2" stroke-linejoin="round">
      <path d="M30 200 Q30 165 60 160 Q63 126 90 122 Q118 118 121 152 Q148 146 152 174 Q156 198 134 207 L55 207 Q30 207 30 200Z"/>
      <path d="M32 204 Q12 220 22 234 Q33 222 44 207"/>
      <path d="M150 204 Q170 220 160 234 Q149 222 138 207"/>
    </g>
    <g fill="#8a5c00" stroke="#b07800" stroke-width="0.9" opacity="0.8">
      <path d="M150 260 Q150 242 166 239 Q168 223 179 221 Q190 219 192 233 Q202 230 204 243 Q206 254 197 258 L160 258 Q150 258 150 260Z"/>
      <path d="M152 257 Q143 266 147 274 Q152 267 158 258"/>
      <path d="M202 257 Q211 266 207 274 Q202 267 196 258"/>
    </g>
  </svg>

  <!-- Bamboo — left side -->
  <svg class="absolute left-0 top-0 h-full w-36 opacity-[0.09] pointer-events-none" viewBox="0 0 144 900" preserveAspectRatio="xMinYMin meet" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Stalk 1 -->
    <path d="M28 900 Q24 800 28 700 Q32 600 28 500 Q24 400 28 300 Q32 200 28 100 Q24 20 28 0" stroke="#6aaa6a" stroke-width="12" stroke-linecap="round"/>
    <ellipse cx="28" cy="750" rx="10" ry="5" fill="#5a8a5a"/>
    <ellipse cx="28" cy="650" rx="10" ry="5" fill="#5a8a5a"/>
    <ellipse cx="28" cy="550" rx="10" ry="5" fill="#5a8a5a"/>
