    <ellipse cx="28" cy="250" rx="10" ry="5" fill="#5a8a5a"/>
    <ellipse cx="28" cy="150" rx="10" ry="5" fill="#5a8a5a"/>
    <!-- Leaves stalk 1 -->
    <path d="M28 700 Q65 682 72 700 Q50 697 28 700" fill="#5a8a5a"/>
    <path d="M28 600 Q-8 582 -16 598 Q4 596 28 600" fill="#5a8a5a"/>
