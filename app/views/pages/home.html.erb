    <ellipse cx="60" cy="820" rx="8" ry="4" fill="#4a7a4a" opacity="0.7"/>
    <ellipse cx="60" cy="740" rx="8" ry="4" fill="#4a7a4a" opacity="0.7"/>
    <ellipse cx="60" cy="660" rx="8" ry="4" fill="#4a7a4a" opacity="0.7"/>
    <ellipse cx="60" cy="580" rx="8" ry="4" fill="#4a7a4a" opacity="0.7"/>
    <ellipse cx="60" cy="500" rx="8" ry="4" fill="#4a7a4a" opacity="0.7"/>
    <ellipse cx="60" cy="420" rx="8" ry="4" fill="#4a7a4a" opacity="0.7"/>
    <path d="M60 780 Q90 764 96 778 Q76 775 60 780" fill="#4a7a4a" opacity="0.7"/>
    <path d="M60 700 Q32 684 26 698 Q42 695 60 700" fill="#4a7a4a" opacity="0.7"/>
    <path d="M60 620 Q88 605 93 618 Q74 615 60 620" fill="#4a7a4a" opacity="0.7"/>
    <path d="M60 540 Q34 524 28 538 Q44 535 60 540" fill="#4a7a4a" opacity="0.7"/>
  </svg>

  <!-- Bamboo — right side (mirrored) -->
  <svg class="absolute right-0 top-0 h-full w-36 opacity-[0.09] pointer-events-none" viewBox="0 0 144 900" preserveAspectRatio="xMaxYMin meet" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M116 900 Q120 800 116 700 Q112 600 116 500 Q120 400 116 300 Q112 200 116 100 Q120 20 116 0" stroke="#6aaa6a" stroke-width="12" stroke-linecap="round"/>
    <ellipse cx="116" cy="750" rx="10" ry="5" fill="#5a8a5a"/>
    <ellipse cx="116" cy="650" rx="10" ry="5" fill="#5a8a5a"/>
    <ellipse cx="116" cy="550" rx="10" ry="5" fill="#5a8a5a"/>
    <ellipse cx="116" cy="450" rx="10" ry="5" fill="#5a8a5a"/>
    <ellipse cx="116" cy="350" rx="10" ry="5" fill="#5a8a5a"/>
    <ellipse cx="116" cy="250" rx="10" ry="5" fill="#5a8a5a"/>
    <ellipse cx="116" cy="150" rx="10" ry="5" fill="#5a8a5a"/>
    <path d="M116 700 Q79 682 72 700 Q94 697 116 700" fill="#5a8a5a"/>
    <path d="M116 600 Q152 582 160 598 Q140 596 116 600" fill="#5a8a5a"/>
    <path d="M116 500 Q81 483 75 499 Q96 496 116 500" fill="#5a8a5a"/>
    <path d="M116 400 Q150 382 157 398 Q138 396 116 400" fill="#5a8a5a"/>
    <path d="M116 300 Q80 282 74 298 Q94 295 116 300" fill="#5a8a5a"/>
    <path d="M116 200 Q149 182 156 198 Q136 196 116 200" fill="#5a8a5a"/>
    <path d="M84 900 Q87 820 84 740 Q81 660 84 580 Q87 500 84 420 Q81 340 84 260 Q87 180 84 100" stroke="#5a9a5a" stroke-width="9" stroke-linecap="round" opacity="0.7"/>
    <ellipse cx="84" cy="820" rx="8" ry="4" fill="#4a7a4a" opacity="0.7"/>
    <ellipse cx="84" cy="740" rx="8" ry="4" fill="#4a7a4a" opacity="0.7"/>
    <ellipse cx="84" cy="660" rx="8" ry="4" fill="#4a7a4a" opacity="0.7"/>
    <ellipse cx="84" cy="580" rx="8" ry="4" fill="#4a7a4a" opacity="0.7"/>
    <ellipse cx="84" cy="500" rx="8" ry="4" fill="#4a7a4a" opacity="0.7"/>
    <path d="M84 780 Q54 764 48 778 Q68 775 84 780" fill="#4a7a4a" opacity="0.7"/>
    <path d="M84 700 Q112 684 118 698 Q102 695 84 700" fill="#4a7a4a" opacity="0.7"/>
    <path d="M84 620 Q56 605 51 618 Q70 615 84 620" fill="#4a7a4a" opacity="0.7"/>
    <path d="M84 540 Q110 524 116 538 Q100 535 84 540" fill="#4a7a4a" opacity="0.7"/>
  </svg>

  <!-- Subtle warm glow behind text area -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 40% at 50% 45%, rgba(20,35,60,0.6) 0%, transparent 100%)"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-24">
    <!-- Trust badge -->
    <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 text-white/80 text-sm mb-8">
      <span class="w-2 h-2 bg-primary-400 rounded-full animate-pulse"></span>
      Более 500 пациентов прошли лечение
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-extrabold text-white mb-6 leading-tight">
      Лечение в Китае —<br>
      <span class="text-primary-400">доступно</span>, безопасно,<br>
      эффективно
    </h1>

    <p class="text-lg sm:text-xl text-slate-300 mb-10 max-w-2xl mx-auto leading-relaxed">
      Айаши — ваш личный куратор от заявки до возвращения домой. Лучшие клиники Китая, русскоязычное сопровождение, прозрачные цены.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <%= link_to contacts_path, class: "btn-primary text-base px-8 py-4" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        Оставить заявку
      <% end %>
      <%= link_to services_page_path, class: "btn-outline text-base px-8 py-4" do %>
        Наши услуги
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>

    <!-- Stats -->
    <div class="mt-16 grid grid-cols-3 gap-8 max-w-lg mx-auto">
      <div class="text-center">
        <div class="text-3xl font-display font-bold text-gold-400">10+</div>
        <div class="text-slate-400 text-sm mt-1">лет опыта</div>
      </div>
      <div class="text-center border-x border-white/10">
        <div class="text-3xl font-display font-bold text-gold-400">500+</div>
        <div class="text-slate-400 text-sm mt-1">пациентов</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-display font-bold text-gold-400">15+</div>
        <div class="text-slate-400 text-sm mt-1">клиник-партнёров</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 text-white/40 animate-bounce">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<!-- Services Preview -->
<% if @featured_services.any? %>
<section id="services" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="section-title">Наши услуги</h2>
      <p class="section-subtitle mx-auto text-center">Высококачественное медицинское обслуживание в ведущих клиниках Китая</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @featured_services.each do |service| %>
        <div class="card overflow-hidden group">
          <!-- Service image / placeholder -->
          <div class="h-44 bg-gradient-to-br from-primary-50 to-primary-100 flex items-center justify-center overflow-hidden">
            <% if service.image.attached? %>
              <%= image_tag service.image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", alt: service.name %>
            <% else %>
              <div class="text-center">
                <div class="w-16 h-16 mx-auto bg-primary-200 rounded-2xl flex items-center justify-center mb-2">
                  <svg class="w-8 h-8 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                  </svg>
                </div>
              </div>
            <% end %>
          </div>

          <div class="p-5">
            <span class="badge bg-primary-100 text-primary-700 mb-3"><%= service.category_label %></span>
            <h3 class="font-display font-semibold text-lg text-ink mb-2"><%= service.name %></h3>
            <% if service.description.present? %>
              <p class="text-gray-500 text-sm leading-relaxed line-clamp-2 mb-4"><%= service.description %></p>
            <% end %>
            <div class="flex items-center justify-between">
              <span class="text-primary-600 font-semibold text-base"><%= service.price_display %></span>
              <%= link_to "Узнать стоимость →", contacts_path, class: "text-sm text-gray-400 hover:text-primary-600 transition-colors" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="text-center mt-10">
      <%= link_to services_page_path, class: "btn-secondary border border-primary-200 px-8 py-3" do %>
        Все услуги и цены
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- Why Us -->
<section class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="section-title">Почему выбирают нас</h2>
      <p class="section-subtitle mx-auto text-center">Мы берём на себя все организационные вопросы — вы сосредоточены на лечении</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% [
        { icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", title: "Сертифицированные клиники", desc: "Работаем только с аккредитованными медицинскими учреждениями Китая с международными стандартами качества" },
        { icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z", title: "Персональный куратор", desc: "Ваш русскоязычный куратор сопровождает вас на каждом этапе — от выбора клиники до возвращения домой" },
        { icon: "M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z", title: "Трансфер и виза", desc: "Помогаем с оформлением медицинской визы, организуем трансфер и размещение рядом с клиникой" },
        { icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z", title: "Прозрачные цены", desc: "Полная стоимость лечения обсуждается до поездки. Никаких скрытых платежей и неожиданных расходов" },
        { icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z", title: "Гарантия качества", desc: "Контролируем весь процесс лечения и гарантируем соответствие заявленным стандартам медицинской помощи" },
        { icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z", title: "Поддержка 24/7", desc: "Наши специалисты на связи круглосуточно во время вашего пребывания в Китае" }
