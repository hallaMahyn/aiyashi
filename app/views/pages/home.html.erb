  <div class="absolute bottom-0 inset-x-0 h-px" style="background: linear-gradient(90deg, transparent 0%, rgba(180,30,30,0.6) 30%, rgba(200,150,20,0.6) 70%, transparent 100%)"></div>

  <!-- 祥云 Auspicious clouds — top right -->
