# Bundler
/.bundle
/vendor/bundle

# Logs
/log/*
!/log/.keep

# Temp files
/tmp/*
!/tmp/.keep

# Database
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-shm
/db/*.sqlite3-wal
/storage/*.sqlite3
/storage/*.sqlite3-shm
/storage/*.sqlite3-wal

# Environment
.env
.env.*
!/env.example

# Assets
/public/assets
/public/packs
/node_modules

# Active Storage (local dev)
/storage/*
!/storage/.keep

# System
.DS_Store
*.swp
*.swo
